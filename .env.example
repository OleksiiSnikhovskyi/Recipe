# Recipe Automation System — Environment Configuration
# Copy this file to .env and fill in with your actual credentials
# NEVER commit .env to git — it contains secrets

# =============================================
# YouTube API Configuration
# =============================================
# Get from: https://console.cloud.google.com/
# Create API key for YouTube Data API v3
YOUTUBE_API_KEY=your_youtube_api_key_here
YOUTUBE_PLAYLIST_ID=PL3lTxqA4f3PhmxU9HEd1Lk17ZoeP4bhfz
YOUTUBE_PLAYLIST_URL=https://youtube.com/playlist?list=PL3lTxqA4f3PhmxU9HEd1Lk17ZoeP4bhfz&si=J0qkY1SP0q2Lx4AM
# Polling interval in minutes (60 = 1 hour, 180 = 3 hours)
YOUTUBE_POLL_INTERVAL_MINUTES=180

# =============================================
# Nextcloud Configuration
# =============================================
NEXTCLOUD_URL=https://nextcloud.csc-ua.tech
NEXTCLOUD_USER=your_nextcloud_email@example.com
NEXTCLOUD_DAV_USER=your_dav_username
NEXTCLOUD_PASSWORD=your_nextcloud_password
NEXTCLOUD_RECIPE_FOLDER=/Documents/Recipe
# If using OAuth token instead of password, set:
# NEXTCLOUD_AUTH_TYPE=token

# =============================================
# Telegram Bot Configuration
# =============================================
# Create bot with @BotFather on Telegram
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklmnoPQRstUVwxyzABCdeFGH
TELEGRAM_CHAT_ID=your_chat_id_here
# Optional: separate admin chat for errors
TELEGRAM_ADMIN_CHAT_ID=your_admin_chat_id_here

# =============================================
# AI/LLM Configuration
# =============================================
# Choose provider: "ollama" (local) or "openai" (cloud)
LLM_PROVIDER=ollama

# For Ollama (Miledy)
OLLAMA_BASE_URL=http://100.100.209.24:11434
OLLAMA_MODEL=qwen3:8b
# Fallback models (comma-separated)
OLLAMA_FALLBACK_MODELS=qwen2.5:7b,llama3.2:3b
OLLAMA_TIMEOUT_SECONDS=600
MAX_SOURCE_TEXT_CHARS=24000

# YouTube transcription: captions first, local Whisper as fallback
TRANSCRIPTION_ENABLED=true
WHISPER_FALLBACK_ENABLED=true
WHISPER_MODEL=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# For OpenAI (cloud)
OPENAI_API_KEY=sk-your_openai_api_key_here
OPENAI_MODEL=gpt-4
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2000

# =============================================
# PostgreSQL Configuration (Markiz)
# =============================================
DB_HOST=100.81.127.54
DB_PORT=5432
DB_NAME=recipe_db
DB_USER=recipe_user
DB_PASSWORD=your_recipe_db_password_here
RECIPE_DB_PASSWORD=your_recipe_db_password_here
# Connection pool settings
DB_POOL_MIN=2
DB_POOL_MAX=10

# =============================================
# n8n Integration
# =============================================
N8N_BASE_URL=https://n8n.csc-ua.tech
N8N_API_KEY=your_n8n_api_key_here
# Webhook base URL (can be same as N8N_BASE_URL)
N8N_WEBHOOK_BASE_URL=https://n8n.csc-ua.tech/webhook
# n8n credentials IDs (get from n8n UI)
N8N_CREDENTIAL_YOUTUBE_ID=youtube_123
N8N_CREDENTIAL_NEXTCLOUD_ID=nextcloud_123
N8N_CREDENTIAL_TELEGRAM_ID=telegram_123

# =============================================
# File Processing Configuration
# =============================================
# Temporary directory for file processing
TEMP_DIR=/tmp/recipe-processing
# Directory for generated recipe DOCX files
DOCX_OUTPUT_DIR=/opt/recipe-automation/output/docx
# LibreOffice path (for PDF conversion)
LIBREOFFICE_PATH=/usr/bin/soffice
# Max file size for DOCX (in MB)
MAX_DOCX_SIZE=50
# PDF conversion timeout (seconds)
PDF_CONVERSION_TIMEOUT=30

# =============================================
# Python Scripts Configuration
# =============================================
# Scripts can be run locally or via n8n HTTP nodes
SCRIPTS_BASE_URL=http://localhost:5000
PYTHON_SCRIPT_TIMEOUT=60

# =============================================
# Logging Configuration
# =============================================
LOG_LEVEL=info
LOG_FILE=/var/log/recipe-automation/app.log
# Keep logs for N days
LOG_RETENTION_DAYS=30

# =============================================
# Feature Flags
# =============================================
# Enable manual regeneration via Telegram
ENABLE_TELEGRAM_REGENERATE=true
# Enable nutrition calculation
ENABLE_NUTRITION_CALC=true
# Enable PDF generation (disable if LibreOffice unavailable)
ENABLE_PDF_GENERATION=true
# Enable Nextcloud upload
ENABLE_NEXTCLOUD_UPLOAD=true

# =============================================
# Email Notifications (Optional)
# =============================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password
# SMTP_FROM=Recipe Bot <noreply@your-domain>
# NOTIFY_EMAIL=your_email@gmail.com
